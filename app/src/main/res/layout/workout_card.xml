<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:orientation="vertical"
    android:padding="18dp"
    android:background="@drawable/rounded_card_background">

    <TextView
        android:id="@+id/tvWorkoutName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Силовая тренировка"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        tools:text="Силовая грудь"/>

    <TextView
        android:id="@+id/tvExerciseCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5 упражнений"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="27 янв"
        android:textSize="12sp"
        android:textColor="@color/text_hint"
        android:layout_marginTop="2dp"/>

    <LinearLayout
        android:id="@+id/actionsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp">

        <Button
            android:id="@+id/btnStartWorkout"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Начать"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/accent_progress"/>

        <Button
            android:id="@+id/btnEditWorkout"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Изменить"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/background_tertiary"/>

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Удалить"
            android:textColor="@color/error"
            android:backgroundTint="@color/background_tertiary"/>
    </LinearLayout>

</LinearLayout>