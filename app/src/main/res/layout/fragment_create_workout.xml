<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="Назад" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Редактирование тренировки"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/text_primary"/>
        </LinearLayout>

        <!-- WORKOUT CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="Название тренировки"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etWorkoutName"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Например: Грудь + трицепс"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="16dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- EXERCISE TITLE -->
        <TextView
            android:text="Добавить упражнение"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- EXERCISE CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="24dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/card_stroke">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <EditText
                    android:id="@+id/etExerciseName"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Название упражнения"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="16dp"/>

                <!-- Контейнер для подсказок поиска -->
                <LinearLayout
                    android:id="@+id/suggestionsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:background="@drawable/bg_input"
                    android:layout_marginTop="4dp"/>

                <!-- SETS + REPS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <EditText
                        android:id="@+id/etSets"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:hint="Подходы"
                        android:inputType="number"
                        android:background="@drawable/bg_input"/>

                    <Space
                        android:layout_width="8dp"
                        android:layout_height="1dp"/>

                    <EditText
                        android:id="@+id/etReps"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:hint="Повторы"
                        android:inputType="number"
                        android:background="@drawable/bg_input"/>
                </LinearLayout>

                <!-- WEIGHT + REST -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <EditText
                        android:id="@+id/etWeight"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:hint="Вес (кг)"
                        android:inputType="numberDecimal"
                        android:background="@drawable/bg_input"/>

                    <Space
                        android:layout_width="8dp"
                        android:layout_height="1dp"/>

                    <EditText
                        android:id="@+id/etRest"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:hint="Отдых (сек)"
                        android:inputType="number"
                        android:background="@drawable/bg_input"/>
                </LinearLayout>

                <!-- Кнопка добавления/применения упражнения -->
                <Button
                    android:id="@+id/createWorkoutButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Добавить упражнение"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/accent_training"
                    android:layout_marginTop="16dp"/>

                <!-- Кнопка отмены редактирования -->
                <Button
                    android:id="@+id/btnCancelEdit"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Отмена"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/text_secondary"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- СПИСОК УПРАЖНЕНИЙ -->
        <TextView
            android:text="Упражнения тренировки"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:id="@+id/containerExercises"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

        <!-- КНОПКА СОХРАНЕНИЯ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCompleteWorkout"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="Сохранить изменения"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/primary"
            app:cornerRadius="18dp"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>