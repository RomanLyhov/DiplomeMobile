<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/rounded_card_background"
    android:orientation="vertical"
    android:padding="20dp"
    android:elevation="4dp"
    android:outlineProvider="background"
    android:clipToOutline="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvExerciseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Жим штанги лежа"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Индикатор начального веса -->
            <TextView
                android:id="@+id/tvInitialWeightBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏁 Начальный: 60 кг"
                android:textSize="11sp"
                android:textColor="@color/accent_training"
                android:visibility="gone"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Кнопка "Добавить прогресс" -->
        <TextView
            android:id="@+id/btnAddProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📈"
            android:textSize="18sp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <!-- Кнопка редактирования -->
        <TextView
            android:id="@+id/btnEditExercise"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✎"
            android:textSize="18sp"
            android:textColor="@color/accent_training"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp" />

        <!-- Кнопка удаления -->
        <TextView
            android:id="@+id/btnRemoveExercise"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textSize="18sp"
            android:textColor="@color/text_secondary"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="4"
        android:paddingVertical="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ПОДХОДЫ"
                android:textSize="10sp"
                android:textColor="@color/text_hint"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tvSets"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/divider"
            android:layout_marginVertical="4dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ПОВТОРЫ"
                android:textSize="10sp"
                android:textColor="@color/text_hint"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tvReps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/divider"
            android:layout_marginVertical="4dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ВЕС"
                android:textSize="10sp"
                android:textColor="@color/text_hint"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tvWeight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="60"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="кг"
                android:textSize="10sp"
                android:textColor="@color/text_hint" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="@color/divider"
            android:layout_marginVertical="4dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ОТДЫХ"
                android:textSize="10sp"
                android:textColor="@color/text_hint"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tvRest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="90"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:layout_marginTop="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="сек"
                android:textSize="10sp"
                android:textColor="@color/text_hint" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>